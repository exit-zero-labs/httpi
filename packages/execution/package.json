{
  "name": "@e0l/httpi-execution",
  "private": true,
  "version": "0.1.0",
  "description": "Execution orchestration for httpi.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@e0l/httpi-contracts": "workspace:*",
    "@e0l/httpi-definitions": "workspace:*",
    "@e0l/httpi-http": "workspace:*",
    "@e0l/httpi-runtime": "workspace:*",
    "@e0l/httpi-shared": "workspace:*"
  }
}
