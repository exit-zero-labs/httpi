{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/exit-zero-labs/runmark/main/packages/contracts/schemas/eval.schema.json",
  "title": "runmark eval definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "target", "dataset"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "eval"
    },
    "title": {
      "type": "string"
    },
    "env": {
      "type": "string",
      "description": "Environment id used for each row unless overridden."
    },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["run"],
          "properties": {
            "run": {
              "type": "string",
              "description": "Id of the run to execute for every dataset row."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["request"],
          "properties": {
            "request": {
              "type": "string",
              "description": "Id of the request to execute for every dataset row."
            }
          }
        }
      ]
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["jsonl", "csv"],
          "description": "Dataset on-disk format."
        },
        "path": {
          "type": "string",
          "description": "Path to the dataset file, relative to the project's runmark/ directory."
        }
      }
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1,
      "description": "Upper bound on rows running in parallel. Defaults to 1."
    }
  }
}
