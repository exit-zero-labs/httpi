{
  "name": "@exit-zero-labs/runmark",
  "version": "0.5.0",
  "description": "Repo-native HTTP workflows for developers, scripts, and coding agents via the `runmark` CLI and `runmark mcp` stdio server.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "runmark": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/runmark.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/runmark/issues"
  },
  "homepage": "https://runmark.exitzerolabs.com",
  "keywords": [
    "runmark",
    "http",
    "api",
    "testing",
    "workflow",
    "cli",
    "mcp",
    "yaml",
    "automation",
    "ai",
    "agent"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/exit-zero-labs"
    },
    {
      "type": "opencollective",
      "url": "https://opencollective.com/exit-zero-labs"
    }
  ],
  "publishConfig": {
    "access": "public",
    "directory": "publish"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json && node ../../scripts/build-published-app.mjs apps/cli",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@exit-zero-labs/runmark-contracts": "workspace:*",
    "@exit-zero-labs/runmark-execution": "workspace:*",
    "@exit-zero-labs/runmark-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
