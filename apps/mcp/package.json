{
  "name": "@e0l/mcp",
  "private": true,
  "version": "0.1.0",
  "description": "MCP entrypoint for httpi.",
  "type": "module",
  "bin": {
    "mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@e0l/httpi-contracts": "workspace:*",
    "@e0l/httpi-execution": "workspace:*",
    "@e0l/httpi-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
